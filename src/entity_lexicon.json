{
  "metadata": {
    "purpose": "Domain lexicon for Nigerian fintech ASR post-processing. Low-risk closed-set entities can be autocorrected; high-risk identifiers should be confirmed.",
    "sources": [
      "CBN Payment Service Providers list",
      "CBN Deposit Money Banks list as at April 26, 2024",
      "YPIT N-ATLaS/Whisper benchmark observed ASR errors"
    ],
    "notes": [
      "Do not include general Yoruba words like owó/ọwọ́ here. Those are language-understanding issues, not closed-set financial entities.",
      "This lexicon should be extended from future benchmark errors, not treated as final."
    ],
    "unsafe_observed_mistranscriptions": {
      "VBank": [
        "the bank",
        "fi banka"
      ],
      "BVN": [
        "ven"
      ],
      "Kuda": [
        "colder c"
      ]
    }
